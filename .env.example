# Admin backend — copy to .env.local for local dev, set the same in Vercel.

# Single shared password for the /admin login (choose a strong one).
ADMIN_PASSWORD=change-me

# Secret used to sign the session cookie. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-byte-base64-string

# Redis connection string (Vercel Marketplace → Redis). Injected
# automatically once the database is connected to the Vercel project.
# For LOCAL dev it is OPTIONAL: if absent, vacation data is stored in a
# local file at .data/vacations.json instead.
STORAGE_REDIS_URL=
